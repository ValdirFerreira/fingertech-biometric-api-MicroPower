<?xml version="1.0" encoding="utf-8"?>
<!--
  Perfil de publicacao "Installer" para o Visual Studio.
  Ao clicar em Publish com este perfil:
    1. Compila em Release/win-x64
    2. Publica os arquivos em ..\publish\
    3. Roda o Inno Setup automaticamente
    4. Gera o .exe instalador em ..\installer-output\
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishDir>$(MSBuildProjectDirectory)\..\publish\</PublishDir>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <!-- Garante que o target GenerateInstaller rode apos o publish -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
